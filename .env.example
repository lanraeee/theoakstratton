# ============================================================================
# OAKSTRATTON BNPL PLATFORM - ENVIRONMENT CONFIGURATION
# ============================================================================
# Copy this file to .env.local (development) or configure in Railway (production)
# See DEPLOYMENT.md for detailed setup instructions

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
PORT=3000
NODE_ENV=development
# For local development: http://localhost:5173
# For production: https://yourdomain.com or https://your-app.up.railway.app
VITE_API_URL=http://localhost:3000
API_URL=http://localhost:3000
CLIENT_URL=http://localhost:5173

# ============================================================================
# DATABASE CONFIGURATION (PostgreSQL)
# ============================================================================
# Local development: Create with: createdb oakstratton_dev
# Railway: Auto-generated when PostgreSQL service is added
DATABASE_URL=postgresql://user:password@localhost:5432/oakstratton_dev

# Optional: Individual database parameters (alternative to DATABASE_URL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=oakstratton_dev
DB_USER=postgres
DB_PASSWORD=your_password

# ============================================================================
# JWT CONFIGURATION (CRITICAL - USE STRONG RANDOM STRINGS)
# ============================================================================
# Generate secure keys: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-long-change-this!
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars-change-this!
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ============================================================================
# CORS AND API CONFIGURATION
# ============================================================================
# Local: http://localhost:5173,http://localhost:3000
# Production: https://yourdomain.com
CORS_ORIGIN=http://localhost:5173,http://localhost:3000
API_KEY=your-secret-api-key-for-leads-endpoint

# ============================================================================
# EMAIL/SMTP CONFIGURATION (Optional)
# ============================================================================
# Gmail: Enable "Less secure app access" or use App Password
# For production: Use SendGrid, AWS SES, or similar service
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
ADMIN_EMAIL=admin@yourdomain.com
EMAIL_FROM_NAME=Oakstratton Team
EMAIL_FROM_ADDRESS=noreply@oakstratton.com
EMAIL_REPLY_TO=support@oakstratton.com

# ============================================================================
# STRIPE CONFIGURATION (Optional)
# ============================================================================
# Get keys from: https://dashboard.stripe.com/apikeys
# Testing: sk_test_*, pk_test_*
# Production: sk_live_*, pk_live_*
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ============================================================================
# reCAPTCHA CONFIGURATION (Optional)
# ============================================================================
# Get from: https://www.google.com/recaptcha/admin
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key
RECAPTCHA_SITE_KEY=your-recaptcha-site-key

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
APP_NAME=Oakstratton
APP_DOMAIN=http://localhost:3000
SUPPORT_EMAIL=support@oakstratton.com

# ============================================================================
# LOGGING AND FEATURES
# ============================================================================
LOG_LEVEL=info
LOG_FILE=./logs/app.log
ENABLE_ANALYTICS=true
ENABLE_EMAIL_TRACKING=true
ENABLE_2FA=false

# ============================================================================
# PRODUCTION SETTINGS (Railway)
# ============================================================================
# Uncomment and configure these for production deployment
# NODE_ENV=production
# DATABASE_URL=postgresql://user:password@host:5432/db (auto-set by Railway)
# VITE_API_URL=https://your-app.up.railway.app
# API_URL=https://your-app.up.railway.app
# CLIENT_URL=https://your-app.up.railway.app
# CORS_ORIGIN=https://your-app.up.railway.app
# JWT_SECRET=<strong-random-string>
# JWT_REFRESH_SECRET=<strong-random-string>
# SMTP_HOST=smtp.sendgrid.net (or your email service)
# SMTP_USER=apikey
# SMTP_PASS=<SendGrid API key>
# NODE_TLS_REJECT_UNAUTHORIZED=0 (only if needed for SSL issues)
