{
  "name": "oakstratton-bnpl",
  "version": "2.0.0",
  "description": "Modern BNPL landing page with admin dashboard",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "server:dev": "nodemon server.js",
    "client:dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "build:prod": "npm run build && node server.js",
    "start": "node server.js",
    "lint": "eslint src --ext .ts,.tsx",
    "type-check": "tsc --noEmit"
  },
  "keywords": ["bnpl", "payment-plans", "admin-dashboard", "modern", "react"],
  "author": "Oakstratton",
  "license": "ISC",
  "dependencies": {
    "express": "^4.18.2",
    "nodemailer": "^6.9.4",
    "dotenv": "^16.3.1",
    "cors": "^2.8.5",
    "body-parser": "^1.20.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "validator": "^13.11.0",
    "axios": "^1.6.7",
    "stripe": "^14.11.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.1.2",
    "pg": "^8.11.3",
    "papaparse": "^5.4.1",
    "mjml": "^4.15.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "zustand": "^4.4.2",
    "axios": "^1.6.7",
    "framer-motion": "^10.16.16",
    "three": "^r128",
    "@react-three/fiber": "^8.15.12",
    "@react-three/drei": "^9.88.8",
    "recharts": "^2.10.4",
    "react-quill": "^2.0.0",
    "clsx": "^2.0.0",
    "dompurify": "^3.0.6"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "concurrently": "^8.2.2",
    "@vitejs/plugin-react": "^4.2.1",
    "vite": "^5.0.10",
    "typescript": "^5.3.3",
    "@types/react": "^18.2.42",
    "@types/react-dom": "^18.2.18",
    "@types/node": "^20.10.6",
    "tailwindcss": "^3.4.1",
    "postcss": "^8.4.32",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.55.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint-plugin-react": "^7.33.2",
    "shadcn-ui": "^0.8.0"
  }
