# Server Configuration
PORT=3000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Database Configuration (PostgreSQL)
# Install PostgreSQL and create database: createdb oakstratton_bnpl
DATABASE_URL=postgresql://user:password@localhost:5432/oakstratton_bnpl
DB_HOST=localhost
DB_PORT=5432
DB_NAME=oakstratton_bnpl
DB_USER=postgres
DB_PASSWORD=your_password

# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
ADMIN_EMAIL=fawaz@belloite.com

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-long!
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars!
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# API Configuration
API_KEY=your-secret-api-key-for-leads-endpoint
CORS_ORIGIN=http://localhost:5173,https://yourdomain.com

# Stripe Configuration
STRIPE_SECRET_KEY=sk_live_your_secret_key
STRIPE_PUBLISHABLE_KEY=pk_live_your_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# reCAPTCHA Configuration
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key
RECAPTCHA_SITE_KEY=your-recaptcha-site-key

# Application Settings
APP_NAME=Oakstratton
APP_DOMAIN=https://oakstratton.com
SUPPORT_EMAIL=support@oakstratton.com

# Email Template Settings
EMAIL_FROM_NAME=Oakstratton Team
EMAIL_FROM_ADDRESS=noreply@oakstratton.com
EMAIL_REPLY_TO=support@oakstratton.com

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# Features
ENABLE_ANALYTICS=true
ENABLE_EMAIL_TRACKING=true
ENABLE_2FA=false
