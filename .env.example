# SMTP Configuration
# Gmail Setup
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# OR Fasthosts Livemail Setup (uncomment to use)
# SMTP_HOST=mail.fasthosts.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-fasthosts-email@yourdomain.com
# SMTP_PASS=your-fasthosts-password

# Admin email
ADMIN_EMAIL=fawaz@belloite.com

# Server
PORT=3000
NODE_ENV=production

# Security
API_KEY=your-secret-api-key-for-leads-endpoint
CORS_ORIGIN=https://yourdomain.com

# Stripe Configuration
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_your_secret_key
STRIPE_PUBLISHABLE_KEY=pk_live_your_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# reCAPTCHA (optional - for spam prevention)
# Get keys from: https://www.google.com/recaptcha/admin
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key
RECAPTCHA_SITE_KEY=your-recaptcha-site-key

# Social Media Links (update in index.html)
# LinkedIn: https://linkedin.com/in/yourprofile
# Twitter: https://twitter.com/yourhandle
# Instagram: https://instagram.com/yourhandle
